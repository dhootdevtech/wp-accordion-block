{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-accordion/accordion-item",
	"version": "0.1.0",
	"title": "Accordion Item",
	"parent": [
		"wp-accordion/accordion"
	],
	"category": "widgets",
	"icon": "smiley",
	"description": "Accordion Item",
	"example": {},
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"titleTag": {
			"type": "string",
			"default": "h3"
		},
		"titleBgColor": {
			"type": "string",
			"default": "#f7f7f7"
		},
		"titleBgHoverColor": {
			"type": "string",
			"default": "#f7f7f7"
		},
		"titleBgActiveColor": {
			"type": "string",
			"default": "#f7f7f7"
		},
		"titleColor": {
			"type": "string",
			"default": "#2984D1"
		},
		"titleHoverColor": {
			"type": "string",
			"default": "#000000"
		},
		"titleActiveColor": {
			"type": "string",
			"default": "#000000"
		},
		"fontTitleSize": {
			"type": "string",
			"default": "18px"
		},
		"fontTitleWeight": {
			"type": "string",
			"default": "600"
		},
		"iconColor":{
            "type": "string",
			"default": "#000"
		},
		"iconHoverColor":{
            "type": "string",
			"default": "#000"
		},
		"iconActiveColor":{
            "type": "string",
			"default": "#000"
		},
		"iconFontSize":{
            "type": "string",
			"default": "12px"
		},
		"isOpen": {
			"type": "boolean",
			"default": true
		},
		"paddingLeftRightTitle": {
			"type": "object",
			"default": {
				"right": "10px",
				"left": "10px"
			}
		},
		"paddingTopBottomTitle": {
			"type": "object",
			"default": {
				"top": "10px",
				"bottom": "10px"
			}
		},
		"paddingTopBottomContent": {
			"type": "object",
			"default": {
				"top": "10px",
				"bottom": "10px"
			}
		},
		"paddingLeftRightContent": {
			"type": "object",
			"default": {
				"left": "10px",
				"right": "10px"
			}
		},
		"contentBgcolor":{
			"type": "string",
			"default": "#ebe9e9"
		},
		"contentColor":{
			"type": "string",
			"default": "#000"
		},
		"iconType": {
			"type": "string",
			"default": "plus"
		},
		"marginTopBottom":{
           "type": "object",
			"default": {
				"top": "10px",
				"bottom": "10px"
			}
		},
		"marginLeftRight":{
           "type": "object",
			"default": {
				"right": "10px",
				"left": "10px"
			}
		},
		"toggleIconsSize":{
			"type": "string",
			"default": "15px"
		},
		"toggleIconsWeight":{
			"type": "string",
			"default": "200"
		}	
	},
	"supports": {
		"html": false
	},
	"textdomain": "wp-accordion-block",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"viewScript": "file:./view.js"
}
