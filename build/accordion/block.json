{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wp-accordion/accordion",
  "title": "Accordion",
  "category": "widgets",
  "icon": "menu",
  "description": "Accordion Container",
  "attributes": {
    "openFirst": {
      "type": "boolean",
      "default": false
    },
    "singleOpen": {
      "type": "boolean",
      "default": false
    },
    "iconType": {
      "type": "string",
      "default": "plus"
    },
    "titleBgColor": {
      "type": "string",
      "default": "#f7f7f7"
    },
    "titleColor": {
      "type": "string",
      "default": "#000000"
    },
    "fontSize": {
      "type": "string",
      "default": "18px"
    },
    "fontWeight": {
      "type": "string",
      "default": "600"
    },
    "border": {
      "type": "string",
      "default": "1px solid #ddd"
    },
    "borderRadius": {
      "type": "string",
      "default": "4px"
    },
    "enableFaqSchema": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js"
}